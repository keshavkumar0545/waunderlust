<% layout("/layouts/boilerplate")%>
<body>
    <div class="row">
    <div class="col-8 offset-2">
    <br>
    <h1>Change Listing!</h1><br>
      <form method="post" action="/listings/<%=listing._id%>?_method=PUT"class="needs-validation" novalidate enctype="multipart/form-data">
       <div> <label for="tiltle" class="form-label">Title</label><br>
        <input type="text" name="title " value="<%=listing.title %>"  class="form-control" required><br></div>

       <div> <label for="description" class="form-label">Description</label><br>
        <textarea type="text" name="description" value="<%=listing.description %>"  class="form-control" required><%=listing.description %></textarea><br>
          <div class="invalid-feedback"> please enter a short description</div>
    </div>
<div class="mb-3">
    Original Image <br>
    <img src="<%= originalimage %>" width="100">
</div>

       <div> <label for="image" class="form-label">Upload Nw IMAGE</label><br>
        <input type="file" name="listing[image]"   class="form-control" ><br></div>
         <div class="row">
        <div class="col col-md-4"><label for="price" class="form-label">Price</label><br>
        <input type="number" name="price" value="<%=listing.price %>"  class="form-control" required><br></div>

       <div class="col col-md-8"> <label for="location" class="form-label">Location</label><br>
        <input type="text" name="location"  value="<%=listing.location %>"  class="form-control" required><br></div></div>

        <div> <label for="country" class="form-label" >Country</label><br>
        <input type="text" name="country" value="<%=listing.country %>"  class="form-control" required><br><br></div>

        <button type="submit" class="btn btn-dark add-btn">update</button>

        <br><br>

        
    </form></div></div>
    
</body>
