<% layout("/layouts/boilerplate")%>


<div class="row">
    <h1 class="col-6 offset-2"> SignUp  on Wanderlust</h1> <br>
    <div class="col-6 offset-2">

        <form  method="post" action="/signup"  class="needs-validation" novalidate>

              <div>  <label for="Username" class="form-label">Usernmae</label><br>
        <input type="text" name="username" id="username" class="form-control"  required><br></div> 

        <div class="invalid-feedback">loos good!</div>

        
              <div>  <label for="email" class="form-label">Email</label><br>
        <input type="email" name="email" id="email" class="form-control"  required><br></div> 


          
              <div>  <label for="password" class="form-label">Password</label><br>
        <input type="password" name="password" id="password" class="form-control"  required><br></div> 
                  

        <button class="btn btn-success">SignUp</button>

        
        </form>



    </div>
</div>